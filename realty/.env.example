# ─── App ───
NODE_ENV=production
APP_URL=https://your-domain.com
TZ=Europe/Kyiv

# ─── Database ───
POSTGRES_USER=realty
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=realty
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── API ───
API_PORT=3001
JWT_SECRET=change_me_to_random_64_chars_string
JWT_TTL=3600

# ─── Telegram ───
# Get from @BotFather
BOT_TOKEN=
# TG IDs of realtors (comma-separated). Get from @userinfobot
REALTOR_TG_IDS=

# ─── Storage ───
UPLOADS_DIR=/app/uploads
MAX_PHOTOS_PER_OBJECT=50
PHOTO_MAX_SIZE_MB=10

# ─── Frontend ───
VITE_API_URL=https://your-domain.com/api
VITE_BOT_USERNAME=YourBotUsername
